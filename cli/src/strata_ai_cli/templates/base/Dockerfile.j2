FROM python:3.12-slim
WORKDIR /app

# Install uv for fast, deterministic dependency resolution
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Install dependencies (resolves from pyproject.toml if uv.lock is absent)
COPY pyproject.toml ./
RUN uv sync --no-dev

# Copy application code
COPY app/ ./app/
COPY agent/ ./agent/

# Security: Non-root user
RUN useradd --create-home --shell /bin/bash strata && chown -R strata:strata /app
USER strata

# Production defaults (override at runtime via --env or Docker Compose)
ENV STRATA_AI_ENV=prod
ENV STRATA_AI_LOG_SERIALIZE=true
ENV PYTHONUNBUFFERED=1

EXPOSE 8000

# Healthcheck aligned with StrataAIApp /health contract
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')"

# Production entrypoint
# Single worker per container. Scale horizontally via orchestrator (K8s, ECS, Cloud Run)
CMD ["uv", "run", "uvicorn", "app.main:build_app", "--factory", "--host", "0.0.0.0", "--port", "8000", "--log-level", "info"]